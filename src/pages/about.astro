---
import Bagas from '../assets/bagas2.png';
import Layout from '../layouts/BlogPost.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import BaseHead from '../components/BaseHead.astro';
---

<div class="container">
<Layout
	title="About Me"
	description="Bagas Tresna Nanda Mustida Sakti - Software Engineering Student | Web Developer | Tech Enthusiast"
	pubDate={new Date('18 December 2025')}
	heroImage={Bagas}
>
<head>
<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
<link 
	rel="stylesheet" 
	href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
>
</head>

	<h1 class="introduction">
		Hello!, I'm Bagas Tresna Nanda Mustida Sakti <i class="bi bi-braces-asterisk"></i>
	</h1>

	<p class="tagline">Software Engineering Student | Code Learner | Tech Enthusiast</p>

	<section class="content-section">
		<p>
			I'm a passionate <strong>Software Engineering student</strong> from <strong>Vocational High School Taruna Bangsa</strong> in Bekasi City, Indonesia. I'm driven by a curiosity to build meaningful solutions through code and constantly exploring new technologies to enhance my skills.
		</p>
		<p>
			With a focus on <strong>web development</strong> and <strong>software engineering</strong>, I enjoy turning creative ideas into functional applications. I believe in writing clean, efficient code and delivering user-friendly solutions.
		</p>
	</section>

	<section class="content-section">
		<h2><i class="bi bi-person-raised-hand"></i> Education</h2>
		<div class="education-card">
			<h3>MIT Attaqwa 01 Bekasi (SD)</h3>
			<p class="subtitle"><strong>MIT Attaqwa 01</strong> | Bekasi, Indonesia</p>

			<ul class="education-details">
				<li><strong>Elementary School 2015 - 2021</strong></li>
			</ul>

			<br />

			<h3>MTS ATTAQWA 03 Babelan Bekasi (SMP)</h3>
			<p class="subtitle"><strong>MTS Attaqwa 03</strong> | Babelan Bekasi</p>

			<ul class="education-details">
				<li><strong>Secondary School 2021 - 2024</strong></li>
				<li><strong>I was a member of the student council for the 2023-2025 period</strong></li>
			</ul>

			<br />

			<h3>Vocational High School (SMK)</h3>
			<p class="subtitle"><strong>SMK Taruna Bangsa</strong> | Bekasi City, Indonesia 2024 - 2027</p>
			
			<ul class="education-details">
				<li><strong>Program:</strong> Software Engineering (Rekayasa Perangkat Lunak)</li>
				<li><strong>Focus Areas:</strong> Web Development, Database Management, Software Design Principles</li>
				<li><strong>Status:</strong> Currently Studying</li>
				<li><strong>Organization:</strong> RPL Production Units</li>
			</ul>

			<h4>Key Learnings:</h4>
			<ul class="learning-list">
				<li>Object-Oriented Programming (OOP)</li>
				<li>Web Application Development</li>
				<li>Project Management Fundamentals</li>
			</ul>
		</div>
	</section>

	<section class="content-section">
		<h2><i class="bi bi-laptop"></i> Tech Stack</h2>

		<div class="tech-category">
			<h3>Frontend Development</h3>
			<ul>
				<li><strong>HTML5</strong> - Semantic markup & structure</li>
				<li><strong>CSS3</strong> - Styling, layout, responsive design</li>
				<li><strong>JavaScript</strong> - Vanilla Js, DOM</li>
				<li><strong>Frameworks/Libraries:</strong> React, Laravel</li>
				<li><strong>Responsive Design Principles</strong></li>
			</ul>
		</div>

		<div class="tech-category">
			<h3>Backend Development</h3>
			<ul>
				<li><strong>PHP</strong> - Server-side scripting</li>
				<li><strong>Laravel</strong> - PHP Web Framework</li>
				<li><strong>Node.js</strong> - JavaScript runtime (basics)</li>
			</ul>
		</div>

		<div class="tech-category">
			<h3>Database & Tools</h3>
			<ul>
				<li><strong>MySQL</strong> - Relational Database Management</li>
				<li><strong>Database Design</strong> - Schema planning, normalization</li>
				<li><strong>Git & GitHub</strong> - Version control & collaboration</li>
				<li><strong>VS Code</strong> - Primary code editor</li>
				<li><strong>Canva</strong> - Primary Design</li>
				<li><strong>NPM</strong> - For install Package</li>
			</ul>
		</div>

		<div class="tech-category">
			<h3>Additional Skills</h3>
			<ul>
				<li>Design Poster</li>
				<li>CRUD Operations</li>
				<li>Excel & Word</li>
				<li>Selling a Product</li>
			</ul>
		</div>
	</section>

	<section class="content-section">
		<h2><i class="bi bi-rocket"></i> Projects & Achievements</h2>

		<div class="project-card">
			<h3>Laravel CRUD Application</h3>
			<p>A comprehensive learning project demonstrating Create, Read, Update, Delete operations using Laravel framework.</p>
			<ul class="project-info">
				<li><strong>Tech:</strong> Laravel, PHP, MySQL, Blade Templates</li>
				<li><strong>Features:</strong> Database migrations, Eloquent ORM, form validation</li>
				<li><strong>Repository:</strong> <a href="https://github.com/BagasHtml/Belajar-Crud-Laravel" target="_blank">Belajar-Crud-Laravel</a></li>
			</ul>
		</div>

		<div class="project-card">
			<h3>Game Suit Simple</h3>
			<p>An interactive Rock-Paper-Scissors web game with modern UI and score tracking.</p>
			<ul class="project-info">
				<li><strong>Tech:</strong> HTML5, CSS3, Vanilla JavaScript</li>
				<li><strong>Features:</strong> Real-time game logic, responsive design, score tracking</li>
				<li><strong>Live Demo:</strong> <a href="https://game-suit-simple.vercel.app" target="_blank">game-suit-simple.vercel.app</a></li>
				<li><strong>Repository:</strong> <a href="https://github.com/BagasHtml/Game-suit-simple" target="_blank">Game-suit-simple</a></li>
			</ul>
		</div>

		<div class="project-card">
			<h3>Weather CLI Application</h3>
			<p>A application that makes it easier for you to check the weather from all cities in the country.</p>
			<ul class="project-info">
				<li><strong>Tech:</strong> JavaScript, NodeJs, Axios, Inquirer, Chalk, Dotenv</li>
				<li><strong>Features:</strong> Real time Weather all Cities in the country</li>
				<li><strong>Repository:</strong> <a href="https://github.com/BagasHtml/Weather-Cli.git">Weather-CLI-App</a></li>
			</ul>
		</div>

		<div class="project-card">
			<h3>Bank Application</h3>
			<p>A application that makes it easier for you to manage the finances you want to save</p>
			<ul class="project-info">
				<li><strong>Tech:</strong> JavaScript, HTML, Css, TypeScript</li>
				<li><strong>Features:</strong> make easier for manage your money</li>
				<li><strong>Live Demo:</strong> <a href="https://aplikasi-bank.vercel.app/">aplikasi-bank.vercel.app</a></li>
				<li><strong>Repository:</strong> <a href="https://github.com/BagasHtml/Aplikasi-Bank.git">Aplikasi-Bank</a></li>
			</ul>
		</div>

		<div class="project-card">
			<h3>Store Catalog</h3>
			<p>A store catalog website that you can develop further. I created it simply because I was learning PHP sessions</p>
			<ul class="project-info">
				<li><strong>Tech:</strong> HTML, Css, PHP, JavaScript</li>
				<li><strong>Features:</strong> Item form, payment form that when you checkout an item, will be added to the payment form</li>
				<li><strong>Repository</strong> <a href="https://github.com/BagasHtml/Katalog-Toko-New.git">Katalog-Toko-New</a></li>
			</ul>
		</div>
	</section>


	<section class="content-section">
		<h2><i class="bi bi-bullseye"></i> Core Competencies</h2>
		<div class="competencies-grid">
			<div class="competency-item">
				<h4>Frontend</h4>
				<p>HTML, CSS, JavaScript</p>
			</div>
			<div class="competency-item">
				<h4>Backend</h4>
				<p>PHP, Laravel</p>
			</div>
			<div class="competency-item">
				<h4>Database</h4>
				<p>MySQL, Sqlite</p>
			</div>
			<div class="competency-item">
				<h4>Tools</h4>
				<p>Git, GitHub, VS Code, Vercel, Canva, NPM</p>
			</div>
			<div class="competency-item">
				<h4>Soft Skills</h4>
				<p>Problem Solving, Team Collaboration, Quick Learning, Public Speaking</p>
			</div>
		</div>
	</section>

	
	<section class="content-section">
		<h2><i class="bi bi-sprout"></i> Currently Learning</h2>
		<ul>
			<li>Newbie Code Learner</li>
			<li>Newbie web development practices</li>
			<li>Linux Open Source</li>
			<li>UI/UX Design</li>
			<li>Newbie Laravel features</li>
		</ul>
	</section>

	<section class="content-section">
		<h2><i class="bi bi-lightbulb"></i> What I Enjoy</h2>
		<ul>
			<li><strong>Building Web Applications:</strong> From concept to deployment</li>
			<li><strong>Problem Solving:</strong> Debugging and optimizing code</li>
			<li><strong>Learning:</strong> Exploring new technologies and frameworks</li>
			<li><strong>Collaboration:</strong> Working with teams on exciting projects</li>
			<li><strong>Open Source:</strong> Contributing to community projects</li>
		</ul>
	</section>

	
	<section class="content-section">
		<h2><i class="bi bi-graph-up"></i> Development Philosophy</h2>
		<div class="philosophy-list">
			<div class="philosophy-item">
				<span class="checkmark"><i class="bi bi-check-circle-fill"></i></span>
				<p><strong>Write clean, readable code</strong> - Future me will thank current me</p>
			</div>
			<div class="philosophy-item">
				<span class="checkmark"><i class="bi bi-check-circle-fill"></i></span>
				<p><strong>User-first approach</strong> - Build solutions that matter</p>
			</div>
			<div class="philosophy-item">
				<span class="checkmark"><i class="bi bi-check-circle-fill"></i></span>
				<p><strong>Continuous learning</strong> - Tech evolves, so do I</p>
			</div>
			<div class="philosophy-item">
				<span class="checkmark"><i class="bi bi-check-circle-fill"></i></span>
				<p><strong>Test thoroughly</strong> - Prevent bugs before deployment</p>
			</div>
			<div class="philosophy-item">
				<span class="checkmark"><i class="bi bi-check-circle-fill"></i></span>
				<p><strong>Document properly</strong> - Clear documentation saves time</p>
			</div>
		</div>
	</section>

	<section class="content-section">
		<h2><i class="bi bi-mortarboard"></i> Goals</h2>

		<div class="goals-container">
			<div class="goals-card">
				<h3>Short Term (6-12 months)</h3>
				<ul>
					<li>Can use Laravel</li>
					<li>Build 5+ portfolio projects use TypeScript or Laravel</li>
					<li>make a good application so that the client is happy</li>
					<li>Improve UI/UX design skills</li>
				</ul>
			</div>

			<div class="goals-card">
				<h3>Long Term (1-3 years)</h3>
				<ul>
					<li>Become a professional software engineer</li>
					<li>Specialize in a specific domain (web apps, mobile, or cloud)</li>
					<li>Lead development teams</li>
					<li>Create impactful software solutions</li>
				</ul>
			</div>
		</div>
	</section>

	
	<section class="content-section">
		<h2><i class="bi bi-link-45deg"></i> Let's Connect</h2>
		<div class="connect-links">
			<a href="https://github.com/BagasHtml" target="_blank" rel="noopener noreferrer">
				<i class="bi bi-github"></i> <strong>GitHub:</strong> BagasHtml
			</a>
			<a href="https://instagram.com/bagas_tresnaa_" target="_blank" rel="noopener noreferrer">
				<i class="bi bi-instagram"></i> <strong>Instagram:</strong> @bagas_tresnaa_
			</a>
			<a href="https://tiktok.com/@BagasHTML" target="_blank" rel="noopener noreferrer">
				<i class="bi bi-tiktok"></i> <strong>TikTok:</strong> @BagasHTML
			</a>
		</div>
		<p>Feel free to reach out if you have any questions or want to collaborate on projects!</p>
	</section>

	<section class="content-section">
		<h2><i class="bi bi-file-text"></i> Fun Facts About Me</h2>
		<ul class="fun-facts">
			<li><i class="bi bi-controller"></i> Gaming enthusiast in my free time</li>
			<li><i class="bi bi-book"></i> Love reading tech blogs and documentation</li>
			<li><i class="bi bi-cup-hot"></i> Coffee-powered developer</li>
			<li><i class="bi bi-music-note"></i> Music helps me focus while coding</li>
			<li><i class="bi bi-stars"></i> Always excited about trying new frameworks</li>
		</ul>
	</section>
</div>
</Layout>

<style>
	.container {
  		animation-name: fadeIn;        
  		animation-duration: 1s;        
  		animation-timing-function: ease-in; 
  		animation-fill-mode: forwards; 
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.introduction {
		font-size: 2.5rem;
		font-weight: bold;
		margin-bottom: 0.5rem;
		line-height: 1.2;
	}

	.tagline {
		font-size: 1.2rem;
		color: var(--text-secondary, #666);
		margin-bottom: 2rem;
		font-weight: 500;
	}

	.content-section {
		margin-bottom: 3rem;
	}

	.content-section h2 {
		font-size: 1.8rem;
		margin-bottom: 1.5rem;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid var(--accent-color, #3b82f6);
	}

	.content-section h3 {
		font-size: 1.3rem;
		margin-top: 1.5rem;
		margin-bottom: 0.75rem;
	}

	.content-section h4 {
		font-size: 1.1rem;
		margin-top: 1rem;
		margin-bottom: 0.5rem;
		font-weight: 600;
	}

	.education-card {
		background: var(--bg-secondary, #f9fafb);
		padding: 1.5rem;
		border-radius: 0.5rem;
		border-left: 4px solid var(--accent-color, #3b82f6);
	}

	.subtitle {
		color: var(--text-secondary, #666);
		font-size: 1rem;
		margin-bottom: 1rem;
	}

	.education-details,
	.learning-list,
	.project-info {
		list-style: none;
		padding: 0;
	}

	.education-details li,
	.learning-list li,
	.project-info li {
		padding: 0.5rem 0;
		padding-left: 1.5rem;
		position: relative;
	}

	.education-details li:before,
	.learning-list li:before,
	.project-info li:before {
		content: "▸";
		position: absolute;
		left: 0;
		color: var(--accent-color, #3b82f6);
		font-weight: bold;
	}

	.tech-category {
		margin-bottom: 1.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border-color, #e5e7eb);
	}

	.tech-category:last-child {
		border-bottom: none;
	}

	.tech-category ul {
		list-style: none;
		padding: 0;
	}

	.tech-category li {
		padding: 0.4rem 0;
		padding-left: 1.5rem;
		position: relative;
	}

	.tech-category li:before {
		content: "→";
		position: absolute;
		left: 0;
		color: var(--accent-color, #3b82f6);
		font-weight: bold;
	}

	.project-card {
		background: var(--bg-secondary, #f9fafb);
		padding: 1.5rem;
		border-radius: 0.5rem;
		margin-bottom: 1.5rem;
		border-left: 4px solid var(--accent-color, #3b82f6);
	}

	.project-card h3 {
		margin-top: 0;
	}

	.project-card a {
		color: var(--accent-color, #3b82f6);
		text-decoration: none;
		font-weight: 500;
	}

	.project-card a:hover {
		text-decoration: underline;
	}

	.competencies-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5rem;
	}

	.competency-item {
		background: var(--bg-secondary, #f9fafb);
		padding: 1.5rem;
		border-radius: 0.5rem;
		text-align: center;
		border-top: 3px solid var(--accent-color, #3b82f6);
	}

	.competency-item h4 {
		margin-top: 0;
		font-size: 1.1rem;
	}

	.competency-item p {
		color: var(--text-secondary, #666);
		font-size: 0.95rem;
		margin: 0;
	}

	.philosophy-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.philosophy-item {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
	}

	.checkmark {
		font-size: 1.5rem;
		flex-shrink: 0;
		color: var(--accent-color, #3b82f6);
	}

	.philosophy-item p {
		margin: 0;
		line-height: 1.5;
	}

	.goals-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 2rem;
	}

	.goals-card {
		background: var(--bg-secondary, #f9fafb);
		padding: 1.5rem;
		border-radius: 0.5rem;
		border-left: 4px solid var(--accent-color, #3b82f6);
	}

	.goals-card h3 {
		margin-top: 0;
		font-size: 1.1rem;
	}

	.goals-card ul {
		list-style: none;
		padding: 0;
	}

	.goals-card li {
		padding: 0.5rem 0;
		padding-left: 1.5rem;
		position: relative;
	}

	.goals-card li:before {
		content: "✓";
		position: absolute;
		left: 0;
		color: var(--accent-color, #3b82f6);
		font-weight: bold;
	}

	.connect-links {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.connect-links a {
		display: inline-block;
		color: var(--accent-color, #3b82f6);
		text-decoration: none;
		padding: 0.5rem 0;
		border-bottom: 1px solid transparent;
		transition: all 0.3s ease;
	}

	.connect-links a:hover {
		border-bottom-color: var(--accent-color, #3b82f6);
	}

	.connect-links i {
		margin-right: 0.5rem;
	}

	.fun-facts {
		list-style: none;
		padding: 0;
	}

	.fun-facts li {
		padding: 0.5rem 0;
		font-size: 1.05rem;
	}

	.fun-facts i {
		margin-right: 0.75rem;
		color: var(--accent-color, #3b82f6);
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		.introduction {
			font-size: 2rem;
		}

		.tagline {
			font-size: 1rem;
		}

		.content-section h2 {
			font-size: 1.5rem;
		}

		.competencies-grid {
			grid-template-columns: 1fr;
		}

		.goals-container {
			grid-template-columns: 1fr;
		}
	}
</style>